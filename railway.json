{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "commands": ["npm install --omit=dev --ignore-scripts && chmod -R 755 node_modules/.bin/ && echo '=== INSTALL COMPLETE ==='"]
        },
        "build": {
          "commands": ["npm run build && echo '=== BUILD COMPLETE ==='"]
        },
        "start": {
          "commands": ["echo '=== STARTING SERVER ===' && node server.js"]
        }
      },
      "runtime": "nodejs_22"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}