{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "commands": ["npm install --omit=dev"]
        },
        "build": {
          "commands": ["npm run build"]
        },
        "start": {
          "commands": ["node server.js"]
        }
      },
      "runtime": "nodejs_22"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}